# Local dev overrides. Copy to `.env` and tweak — docker compose
# auto-loads it. On Coolify, the magic SERVICE_* vars supersede these.

# Comma-separated subdomain allowlist (e.g. seattle,sfbay,portland).
# Empty = poll every Craigslist site (~700, slow + may trip rate limits).
POLL_SITES=

# Optional keyword filter applied to every site (e.g. cessna, "super cub").
POLL_QUERY=

# Cadence. Be polite — Craigslist rate-limits aggressive scrapers.
POLL_INTERVAL_MINUTES=60

# Concurrent fetches per poll cycle.
POLL_WORKERS=8

# Django-Q worker count inside the worker container.
Q_WORKERS=2

# Trade-A-Plane scraper (driven by headless Chromium). Off by default.
# Turn on once you've decided to spend the resource budget AND accepted
# that DataDome will probably block datacenter IPs without a residential
# proxy.
POLL_TRADEAPLANE_ENABLED=false
# Comma-separated category_level1 values to query. TAP options include
# "Single Engine Piston", "Multi Engine Piston", "Turboprop", "Jet",
# "Helicopter", "Light Sport".
POLL_TRADEAPLANE_CATEGORIES=Single Engine Piston
